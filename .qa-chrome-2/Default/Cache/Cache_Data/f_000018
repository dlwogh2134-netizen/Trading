						time: finalTime,
						open: parseFloat(item.open),
						high: parseFloat(item.high),
						low: parseFloat(item.low),
						close: parseFloat(item.close),
						volume: parseFloat(item.volume || 0)
					};
				}).filter((item) => {
					const isValidTime = typeof item.time === "number" && !Number.isNaN(item.time) || typeof item.time === "string" && /^\d{4}-\d{2}-\d{2}$/.test(item.time);
					return isValidTime && !Number.isNaN(item.open) && !Number.isNaN(item.high) && !Number.isNaN(item.low) && !Number.isNaN(item.close);
